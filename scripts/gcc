#!/bin/bash
# GCC wrapper — strips problematic flags, adds workarounds for EDK2 on ARM64
REAL_GCC=/usr/bin/gcc
args=(-fno-lto -Wno-error=maybe-uninitialized -Wno-error=incompatible-pointer-types)
for a in "$@"; do
    case "$a" in
        -Wno-error=unaligned-access|-Wno-unused-const-variable|-Wno-sometimes-uninitialized) ;;
        -mno-outline-atomics|-mno-implicit-float|-flto|-fno-pic|-fno-pie|-ffixed-x18|-mcmodel=small|-mstack-protector-guard=global) ;;
        *) args+=("$a") ;;
    esac
done
exec "$REAL_GCC" "${args[@]}"
