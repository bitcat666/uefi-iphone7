#!/bin/bash
# GCC wrapper — strips clang-specific flags, passes through to real gcc on Linux
args=()
for a in "$@"; do
    case "$a" in
        -Wno-error=unaligned-access|-Wno-unused-const-variable|-Wno-sometimes-uninitialized) ;;
        -mno-outline-atomics|-mno-implicit-float) ;;
        *) args+=("$a") ;;
    esac
done
exec gcc "${args[@]}"
