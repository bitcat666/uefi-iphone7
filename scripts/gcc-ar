#!/bin/bash
args=()
for a in "$@"; do
    case "$a" in
        --plugin=*) ;;
        @*)
            f="${a#@}"
            if [ -f "$f" ]; then
                while IFS= read -r line || [ -n "$line" ]; do
                    line="${line//$'\r'/}"
                    [ -n "$line" ] && args+=("$line")
                done < "$f"
            fi
            ;;
        *) args+=("$a") ;;
    esac
done
exec ar "${args[@]}"
